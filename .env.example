# Copy this file to .env and fill in your values
# cp .env.example .env

# Flask
SECRET_KEY=replace_with_a_long_random_secret_key

# PostgreSQL
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/jet_dashboard

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key

# SMTP (for password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=you@gmail.com
SMTP_FROM_ALIAS=Jet Dashboard
SMTP_USE_TLS=true

# Session
SESSION_TIMEOUT_SECONDS=3600

# Serial / Telemetry
TELEMETRY_ENABLED=1
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
SERIAL_TIMEOUT=1
SERIAL_RECONNECT_DELAY=2

# Service management
JET_SERVICE_NAME=jet_dashboard
JET_RESTART_CMD=sudo systemctl restart jet_dashboard.service
JET_GUNICORN_PID=/run/jet_dashboard.pid
JET_UPDATE_CMD=apt-get update && apt-get upgrade -y
JET_UPDATE_USE_SUDO=true

# Database pool
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Logger script secret (used by app/logger.py)
LOGGER_SECRET=replace_with_a_random_secret
